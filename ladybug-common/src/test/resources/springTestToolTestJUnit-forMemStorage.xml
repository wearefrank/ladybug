<?xml version="1.0" encoding="UTF-8"?>
<beans
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="
		http://www.springframework.org/schema/beans   http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
	"
	default-lazy-init="true"
	>

	<context:component-scan base-package="org.wearefrank.ladybug"/>

	<!-- Use prototype for JUnit tests to reset settings between tests and when run in parallel prevent one test
	     that alters a setting to influence another test

	     When you make checkpoints using bean TestTool then the reports appear in the
	     debug storage. This debug storage is a LogStorage. We add a testStorage
	     to have a CrudStorage to test with.
	-->
	<bean name="testTool" class="org.wearefrank.ladybug.TestTool" scope="prototype">
		<property name="debugStorage">
			<ref bean="debugStorage"/>
		</property>
		<property name="testStorage">
			<ref bean="testStorage"/>
		</property>
		<property name="views">
			<ref bean="views"/>
		</property>
	</bean>

	<bean name="debugStorage" class="org.wearefrank.ladybug.storage.memory.MemoryLogStorage" autowire="byName">
		<property name="initialStorageId">
			<value>2514</value>
		</property>
		<property name="metadataExtractor">
			<bean class="org.wearefrank.ladybug.MetadataExtractor"/>
		</property>
	</bean>

	<bean name="testStorage" class="org.wearefrank.ladybug.storage.memory.MemoryCrudStorage" autowire="byName">
		<property name="name" value="testStorage"/>
		<property name="initialStorageId">
			<value>2614</value>
		</property>
		<property name="metadataExtractor">
			<bean class="org.wearefrank.ladybug.MetadataExtractor"/>
		</property>
	</bean>

	<bean name="views" class="org.wearefrank.ladybug.filter.Views">
		<property name="views">
			<list>
				<ref bean="fakeView"/>
			</list>
		</property>
		<property name="defaultView" ref="defaultView"/>
	</bean>

	<bean name="fakeView" class="org.wearefrank.ladybug.filter.View">
		<!-- ReportApiImpl receives a storage name that is part of the HTTP request.
		     The storage name is resolved by considering the views and the debug storage of each view.
		     When such a debug storage has a matching name, then that is the referred storage. The tests
		     of DownloadReportsTest.java access the CRUD storage "testStorage" via a ReportApiImpl object.
		-->
		<property name="debugStorage">
			<ref bean="testStorage"/>
		</property>
		<property name="name" value="Report name only"/>
		<property name="metadataNames">
			<list>
				<value>storageId</value><!-- Without storageId the report cannot be opened -->
				<value>name</value>
			</list>
		</property>
	</bean>

	<bean name="defaultView" class="java.lang.String">
		<!-- Demonstrate/test setting default view to other than first view in the list  -->
		<constructor-arg value="fakeView"/>
	</bean>
</beans>
